<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>CourseStaffController</servlet-name>
        <servlet-class>Controllers.CourseStaffController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentController</servlet-name>
        <servlet-class>Controllers.StudentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TeacherController</servlet-name>
        <servlet-class>Controllers.TeacherController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StaffController</servlet-name>
        <servlet-class>Controllers.StaffController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ScheduleListServlet</servlet-name>
        <servlet-class>Controllers.ScheduleController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ScheduleTeacherController</servlet-name>
        <servlet-class>Controllers.ScheduleTeacherController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ScheduleStudentController</servlet-name>
        <servlet-class>Controllers.ScheduleStudentController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CourseStaffController</servlet-name>
        <url-pattern>/coursestaff</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentController</servlet-name>
        <url-pattern>/student</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TeacherController</servlet-name>
        <url-pattern>/teacher</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StaffController</servlet-name>
        <url-pattern>/staff</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ScheduleListServlet</servlet-name>
        <url-pattern>/schedule</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ScheduleTeacherController</servlet-name>
        <url-pattern>/scheduleTeacher</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ScheduleStudentController</servlet-name>
        <url-pattern>/scheduleStudent</url-pattern>
    </servlet-mapping>
</web-app>
